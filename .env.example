# Database — SQLite for local dev. Swap to a Postgres connection string
# (Neon / Supabase) for production; Prisma schema works with both via
# the provider field.
DATABASE_URL="file:./dev.db"

# Used to sign session JWTs. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"

# App URL, used for building absolute links in emails etc.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional. Enables a natural-language summary from the AI Budget Advisor
# (src/lib/advisor.ts). Without either of these, the advisor still works
# using rule-based insights computed from your real spending data.
# Set GEMINI_API_KEY (get one free at aistudio.google.com/apikey) or
# ANTHROPIC_API_KEY — if both are set, Gemini is used.
 # GEMINI_API_KEY="YOUR-API-KEY"
# GEMINI_MODEL="gemini-2.0-flash"
# ANTHROPIC_API_KEY=""
